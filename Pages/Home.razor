@page "/"
@using BlazorViaCep.Models
@using System.Text.Json

<PageTitle>Consulta CEP</PageTitle>

<h1>Consulta CEP</h1>

<div class="form-group mb-3">
    <label for="cepInput" class="form-label">Digite o CEP:</label>
    <input type="text" id="cepInput" class="form-control" @bind="cep" placeholder="Ex: 01001-000" />
    
</div>
<button class="btn btn-primary" @onclick="ConsultarCep">Consultar</button>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}
else if (endereco != null)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">Endereço encontrado:</h5>
            <p class="card-text"><strong>CEP:</strong> @endereco.Cep</p>
            <p class="card-text"><strong>Logradouro:</strong> @endereco.Logradouro</p>
            <p class="card-text"><strong>Complemento:</strong> @endereco.Complemento</p>
            <p class="card-text"><strong>Bairro:</strong> @endereco.Bairro</p>
            <p class="card-text"><strong>Localidade:</strong> @endereco.Localidade</p>
            <p class="card-text"><strong>UF:</strong> @endereco.UF</p>
        </div>
    </div>
}

@code {
    private string cep;
    private Endereco endereco;
    private string errorMessage; 
    private async Task ConsultarCep()
    {
        errorMessage = null; 
        try
        {
            var httpClient = new HttpClient();
            var response = await httpClient.GetAsync($"https://viacep.com.br/ws/{cep}/json/");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                endereco = JsonSerializer.Deserialize<Endereco>(json);
            }
            else
            {
                errorMessage = "CEP não encontrado.";
                endereco = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao consultar o CEP: {ex.Message}";
            endereco = null;
        }
    }
}
